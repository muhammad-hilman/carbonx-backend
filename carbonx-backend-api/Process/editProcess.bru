meta {
  name: editProcess
  type: http
  seq: 7
}

put {
  url: {{host}}/api/processes/:id
  body: json
  auth: inherit
}

params:path {
  id: 350253
}

body:json {
  {
    "dpp": {
      "name": "process x",
      "manufacturer": "new manufacturer",
      "serialNumber": "99999"
    },
    "emissionInformation": {
      "scope1": {
        "stationaryCombustion": {
          "CO2": {
            "kg": 5.0
          }
        }
      }
    }
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
