meta {
  name: Create a cursor
  type: http
  seq: 1
}

post {
  url: {{host}}/_db/{{databaseName}}/_api/cursor
  body: json
  auth: basic
}

auth:basic {
  username: root
  password: test
}

body:json {
  {
    "query" : "FOR doc IN shiplogs FILTER doc.mmsi == @mmsi COLLECT AGGREGATE speed = AVERAGE(doc.speed) RETURN speed",
    "bindVars" :  {
                    "mmsi" : "563014970"
                  }
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
