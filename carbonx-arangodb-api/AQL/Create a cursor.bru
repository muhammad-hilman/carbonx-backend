meta {
  name: Create a cursor
  type: http
  seq: 1
}

post {
  url: {{host}}/_db/{{databaseName}}/_api/cursor
  body: json
  auth: basic
}

auth:basic {
  username: root
  password: test
}

body:json {
  {
    "query" : "FOR doc IN products FILTER doc.name == @key RETURN doc",
    "bindVars" :  {
                    "key" : "spaghetti"
                  }
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
