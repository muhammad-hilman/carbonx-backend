meta {
  name: searchProducts
  type: http
  seq: 2
}

get {
  url: {{host}}/api/products/search?productOrigin=newsupplier
  body: none
  auth: inherit
}

params:query {
  productOrigin: newsupplier
  ~type: ingredient
  ~name: onion juice
  ~quantityValue: 0.5
}

settings {
  encodeUrl: true
  timeout: 0
}
